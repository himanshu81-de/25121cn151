#include <stdio.h>
int main()
{
    int a[10], n, i;
    printf("Enter size of array: ");
    scanf("%d", &n);
    printf("Enter array elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }
    printf("Array after right rotation:\n");
    printf("%d ", a[n - 1]);
    for(i = 0; i < n - 1; i++)
    {
        printf("%d ", a[i]);
    }
    return 0;
}
