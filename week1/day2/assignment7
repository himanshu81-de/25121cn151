#include <stdio.h>

int main() {
    int num, product = 1, remainder;

    printf("Enter an integer: ");
    scanf("%d", &num);

    // Handle case when number is 0
    if (num == 0) {
        product = 0;
    } else {
        while (num != 0) {
            remainder = num % 10;       
            product *= remainder;       
            num /= 10;                  
        }
    }

    printf("Product of digits = %d\n", product);

    return 0;
}
