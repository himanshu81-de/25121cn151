#include <stdio.h>
int main()
{
    int binary, dec = 0;
    int digit, power = 1;
    printf("Enter a binary number: ");
    scanf("%d", &binary);
    while (binary > 0)
    {
        digit = binary % 10;
        dec = dec + digit * power;
        power = power * 2;
        binary = binary / 10;
    }
    printf("Decimal number = %d", dec);
    return 0;
}
