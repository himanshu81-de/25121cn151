#include <stdio.h>
int main()
{
    int n, count = 0, digit;
    printf("Enter a binary number: ");
    scanf("%d", &n);
    while(n > 0)
    {
        digit = n % 10;
        if(digit == 1)
        {
            count++;
        }
        n = n / 10;
    }
    printf("Number of set bits = %d", count);
    return 0;
}
