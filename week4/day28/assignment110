#include <stdio.h>
int main()
{
    int choice;
    float balance = 1000, amount;
    printf("1. Deposit\n");
    printf("2. Withdraw\n");
    printf("3. Check Balance\n");
    printf("Enter Choice: ");
    scanf("%d", &choice);
    switch(choice)
    {
        case 1:
            printf("Enter Deposit Amount: ");
            scanf("%f", &amount);
            balance = balance + amount;
            printf("Total Balance = %.2f", balance);
            break;
        case 2:
            printf("Enter Withdraw Amount: ");
            scanf("%f", &amount);
            if(amount <= balance)
            {
                balance = balance - amount;
                printf("Remaining Balance = %.2f", balance);
            }
            else
            {
                printf("Insufficient Balance");
            }
            break;
        case 3:
            printf("Current Balance = %.2f", balance);
            break;
        default:
            printf("Invalid Choice");
    }
    return 0;
}
