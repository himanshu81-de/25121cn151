#include <stdio.h>
int main()
{
    int number = 25, guess;
    printf("Number Guessing Game\n");
    do
    {
        printf("Enter your guess: ");
        scanf("%d", &guess);
        if (guess > number)
        {
            printf("Too High\n");
        }
        else if (guess < number)
        {
            printf("Too Low\n");
        }
        else
        {
            printf("Correct! You guessed the number.\n");
        }
    }
    while (guess != number);
    return 0;
}
