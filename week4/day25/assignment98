#include <stdio.h>
int main() {
    char s1[50], s2[50];
    int i, j;
    scanf("%s", s1);
    scanf("%s", s2);
    printf("Common characters: ");
    for(i = 0; s1[i] != '\0'; i++) {
        for(j = 0; s2[j] != '\0'; j++) {
            if(s1[i] == s2[j]) {
                printf("%c ", s1[i]);
                break;
            }
        }
    }
    return 0;
}
