#include <stdio.h>
int main()
{
    int n, i;
    int bookId[50];
    char bookName[50][50];
    char author[50][50];
    printf("Enter number of books: ");
    scanf("%d", &n);
    for (i = 0; i < n; i++)
    {
        printf("\nEnter details of Book %d\n", i + 1);
        printf("Book ID: ");
        scanf("%d", &bookId[i]);
        printf("Book Name: ");
        scanf("%s", bookName[i]);
        printf("Author Name: ");
        scanf("%s", author[i]);
    }
    printf("\nLibrary Records\n");
    printf("Book ID\tBook Name\tAuthor\n");
    for (i = 0; i < n; i++)
    {
        printf("%d\t%s\t\t%s\n", bookId[i], bookName[i], author[i]);
    }
    return 0;
}
