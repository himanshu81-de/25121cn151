#include <stdio.h>
int main()
{
    int i, n, id[20];
    char name[20][20], company[20][20];
    printf("Enter number of employees: ");
    scanf("%d", &n);
    for (i = 0; i < n; i++)
    {
        printf("\nEmployee %d\n", i + 1);
        printf("ID: ");
        scanf("%d", &id[i]);
        printf("Name: ");
        scanf("%s", name[i]);
        printf("Company: ");
        scanf("%s", company[i]);
    }
    printf("\nEmployee Records\n");
    for (i = 0; i < n; i++)
    {
        printf("%d\t%s\t%s\n", id[i], name[i], company[i]);
    }
    return 0;
}
