#include <stdio.h>
void display(int id[], char name[][20], int marks[], int n)
{
    int i;
    printf("\nStudent Records\n");
    for (i = 0; i < n; i++)
    {
        printf("%d\t%s\t%d\n", id[i], name[i], marks[i]);
    }
}
int main()
{
    int i, n;
    int id[20], marks[20];
    char name[20][20];
    printf("Enter number of students: ");
    scanf("%d", &n);
    for (i = 0; i < n; i++)
    {
        printf("\nStudent %d\n", i + 1);
        printf("ID: ");
        scanf("%d", &id[i]);
        printf("Name: ");
        scanf("%s", name[i]);
        printf("Marks: ");
        scanf("%d", &marks[i]);
    }
    display(id, name, marks, n);
    return 0;
}
